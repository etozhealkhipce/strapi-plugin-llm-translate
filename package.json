{
  "name": "@alkhipce/strapi-plugin-llm-translate",
  "version": "1.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/etozhealkhipce/strapi-plugin-llm-translate.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "Auto-translate localized content into every enabled locale using an LLM provider (Anthropic Claude or OpenAI), right from the Content Manager edit view.",
  "keywords": [
    "strapi",
    "plugin",
    "strapi-plugin",
    "i18n",
    "internationalization",
    "localization",
    "translation",
    "llm",
    "ai",
    "anthropic",
    "claude",
    "openai",
    "gpt"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "tsc -p admin/tsconfig.json --noEmit",
    "test:ts:back": "tsc -p server/tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && npm run verify"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@strapi/admin": "^5.39.0",
    "@strapi/design-system": "^2.2.1",
    "@strapi/icons": "^2.2.1",
    "@strapi/sdk-plugin": "^6.1.1",
    "@strapi/strapi": "^5.39.0",
    "@strapi/typescript-utils": "^5.39.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "prettier": "^3.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.30.4",
    "styled-components": "^6.4.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@strapi/admin": "^5.0.0",
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@strapi/strapi": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intl": "^6.0.0",
    "react-redux": "^8.0.0 || ^9.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "llm-translate",
    "displayName": "LLM Translate",
    "description": "Auto-translate localized content into every enabled locale using an LLM provider (Anthropic or OpenAI)."
  },
  "engines": {
    "node": ">=18.0.0 <=22.x.x",
    "npm": ">=6.0.0"
  },
  "license": "MIT",
  "author": "Dyomin Ilya <i.dyomin@tekmates.pro>"
}
